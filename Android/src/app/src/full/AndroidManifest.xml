 GMS-only manifest pieces for the `full` flavor. These reference Google-Mobile-Services classes
 (AICore, play-services-oss-licenses) and are kept OUT of src/main so the `degoogled` flavor's
 merged manifest stays free of com.google.android.gms.* / AICore references.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Bind to the on-device AICore service (Gemini Nano via ML Kit GenAI) — full flavor only. -->
    <uses-permission android:name="com.google.android.apps.aicore.service.BIND_SERVICE" />

    <application>
        <!-- Themed activities for viewing open-source licenses (play-services-oss-licenses). -->
        <activity
            android:name="com.google.android.gms.oss.licenses.OssLicensesMenuActivity"
            android:exported="true"
            android:theme="@style/Theme.Gallery.OssLicenses" />
        <activity
            android:name="com.google.android.gms.oss.licenses.OssLicensesActivity"
            android:exported="true"
            android:theme="@style/Theme.Gallery.OssLicenses" />
    </application>

</manifest>
