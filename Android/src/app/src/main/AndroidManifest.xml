<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="cc.grepon.relais"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-sdk
        android:minSdkVersion="31"
        android:compileSdkVersion ="35"
        android:targetSdkVersion="35" />

    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Standard (non-Google) permission; backs the read-calendar-events agent skill. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <!-- Doze/app-standby survival for the always-on node: lets the operator grant an
         ignore-battery-optimizations exemption from the control panel. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Watchdog exact alarm (grants temporary FGS-start exemption on crash recovery) -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- NFC workflow triggers (#15): tap a tag to run a prompt template. Optional at runtime. -->
    <uses-permission android:name="android.permission.NFC" />

    <!-- Resurface scheduled notifications + auto-start the node after boot (opt-in) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature android:name="android.hardware.camera.flash"
        android:required="false" />
    <uses-feature android:name="android.hardware.nfc"
        android:required="false" />

    <!-- Package visibility (Android 11+): the notification-triage allowlist picker (#7) lists
         launchable apps so the user can choose which apps to triage. AOSP-only; no QUERY_ALL_PACKAGES. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name="${applicationName}"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="${appIcon}"
        android:label="Relais"
        android:roundIcon="${appIcon}"
        android:supportsRtl="true"
        android:theme="@style/Theme.Relais"
        tools:targetApi="31">
        <!--
          android:configChanges="uiMode" tells the system don't destroy and
          recreate the activity when UI mode changes (e.g. setting dark mode).
          Instead, just recompose the view.
         -->
        <activity
            android:name="cc.grepon.relais.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Relais.SplashScreen"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="uiMode"
            tools:ignore="DiscouragedApi,LockedOrientationActivity">
            <!-- This is for putting the app into launcher -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- This is for deep linking -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="com.ventouxlabs.relais" />
            </intent-filter>
        </activity>

        <!-- FOSS third-party-license screen (AboutLibraries). Internal-only: launched solely from the
             Settings dialog — not exported, no launcher icon. Up-navigates to MainActivity. Works in
             both flavors (no GMS), replacing the old play-services-oss-licenses viewer. -->
        <activity
            android:name="cc.grepon.relais.ui.home.LicensesActivity"
            android:exported="false"
            android:label="Open-source licenses"
            android:parentActivityName=".MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="cc.grepon.relais.MainActivity" />
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false"
            tools:node="merge">
        </service>

        <!-- Relais node control screen (start/stop); exported for launch + automation.
             Has its own LAUNCHER icon ("Relais Node") alongside the stock Gallery icon. The
             start/stop `cmd` intent extra is API-key gated (see RelaisControlActivity). -->
        <activity
            android:name=".RelaisControlActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:label="Relais Node">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Configure surface (control-panel redesign): model picker, HF token, power exemption,
             share/NFC toggles, prompt templates, notification triage — everything setup/rare, one
             tap away from the home screen's MODEL row / CONFIGURE ›. Internal screen, not exported,
             no launcher icon. Up-navigates to RelaisControlActivity. -->
        <activity
            android:name=".RelaisConfigureActivity"
            android:exported="false"
            android:label="Configure"
            android:parentActivityName=".RelaisControlActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="cc.grepon.relais.RelaisControlActivity" />
        </activity>

        <!-- In-app prompt-template editor (#12). Internal screen launched only from the control
             panel — not exported, no launcher icon. Up-navigates to RelaisControlActivity. -->
        <activity
            android:name="cc.grepon.relais.templates.PromptTemplateEditorActivity"
            android:exported="false"
            android:label="Prompt Templates"
            android:parentActivityName=".RelaisControlActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="cc.grepon.relais.RelaisControlActivity" />
        </activity>

        <!-- Notification-triage control panel (#7). Internal screen launched only from the control
             panel — not exported, no launcher icon. Up-navigates to RelaisControlActivity. -->
        <activity
            android:name="cc.grepon.relais.triage.TriageControlActivity"
            android:exported="false"
            android:label="@string/triage_title"
            android:parentActivityName=".RelaisControlActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="cc.grepon.relais.RelaisControlActivity" />
        </activity>

        <!-- On-device notification triage listener (#7). The user-facing grant is Android's
             Notification Access (system-bound via BIND_NOTIFICATION_LISTENER_SERVICE); the in-app
             default-deny allowlist gates what is actually read. Not exported. Strictly opt-in:
             inert until TriageConfig.enabled is set from the control panel. -->
        <service
            android:name="cc.grepon.relais.triage.RelaisNotificationListenerService"
            android:exported="false"
            android:label="@string/triage_listener_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Relais node: headless resident multimodal LLM + LAN endpoint -->
        <service
            android:name=".RelaisNodeService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- Share-sheet inference target (#1, #13). Transparent trampoline: for text/plain it extracts
             the shared text; for image/* (#13) it hands the image URIs to RelaisShareService, which OCRs
             them on-device (bundled ML Kit) and feeds the recognized text to inference. Requests
             notification permission, hands off, then finishes (no window). The trampoline gates the run
             on RelaisInference.isReady() — a share never cold-starts the node. (PDF is a separate feature.) -->
        <activity
            android:name=".share.RelaisShareActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:label="Relais">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="image/*" />
            </intent-filter>
        </activity>

        <!-- Short-lived foreground worker for the share run, so a 30–120s decode survives the
             trampoline finishing. CONSUMER of the resident engine (re-asserts isReady, never
             cold-starts). dataSync FGS type; not exported. -->
        <service
            android:name=".share.RelaisShareService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- NFC workflow tap (#15). Exported no-UI trampoline: a tag encoding
             com.ventouxlabs.relais://workflow/<templateId> launches this, which resolves the #12 template
             and runs it via RelaisShareService → result notification. Opt-in (RelaisConfig.nfcEnabled,
             default false) — inert until enabled; the tag's inline prompt is treated as untrusted and
             runs through plain inference only (no node-tools, no LAN). Consumer of the resident engine
             (gates on RelaisInference.isReady; never cold-starts). -->
        <activity
            android:name=".nfc.RelaisNfcActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:label="Relais NFC">
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="com.ventouxlabs.relais" android:host="workflow" />
            </intent-filter>
        </activity>

        <!-- NFC tag writer (#15). Internal screen launched only from the control panel — not exported.
             Picks a workflow id and writes it to a presented tag via foreground dispatch. -->
        <activity
            android:name=".nfc.NfcWriteActivity"
            android:exported="false"
            android:label="Write NFC Tag"
            android:parentActivityName=".RelaisControlActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="cc.grepon.relais.RelaisControlActivity" />
        </activity>

        <!-- Tasker/Automate intent ABI (#8). Exported transparent trampoline: an automation app (or
             adb) sends com.ventouxlabs.relais.action.INFER with a prompt + the node's API key and captures
             the answer via a package-targeted RESULT broadcast (result_package). The token extra is
             API-key gated (constant-time compare); a missing/bad token runs NO inference. Consumer of
             the resident engine — never cold-starts.
             #44 fix: the decode runs in RelaisAutomationService (below), NOT in this activity — a
             transparent/cross-app launch is torn down before a 30–120s decode completes. So this is a
             gate + hand-off only. Theme.Translucent.NoTitleBar (the proven share theme; NoDisplay's
             finish-before-onResume contract crashed the async path). singleTask is dropped (it forced
             startActivityForResult to RESULT_CANCELED immediately). noHistory + excludeFromRecents keep
             the prompt out of recents/back-stack. No new permission. -->
        <activity
            android:name=".automation.RelaisTaskerActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:label="Relais Inference">
            <intent-filter>
                <action android:name="com.ventouxlabs.relais.action.INFER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Short-lived foreground worker for the Tasker/Automate ABI decode (#8/#44), so a 30–120s
             decode survives the transparent trampoline finishing. CONSUMER of the resident engine
             (re-asserts isReady, never cold-starts); holds the process-global single-flight latch;
             delivers via the package-targeted RESULT broadcast. dataSync FGS type; not exported. -->
        <service
            android:name=".automation.RelaisAutomationService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- Quick Settings tile (#2): live node status + one-tap start/stop. Bind is OS-restricted
             (BIND_QUICK_SETTINGS_TILE), so only the system shade can reach it. -->
        <service
            android:name=".tile.RelaisTileService"
            android:exported="true"
            android:icon="@drawable/ic_relais_tile"
            android:label="Relais Node"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Home-screen widget (#3): Glance quick-prompt surface. Exported so the launcher's
             AppWidgetHost can deliver APPWIDGET_UPDATE; the widget is a CONSUMER (taps never
             cold-start the engine — RunPromptAction gates on RelaisInference.isReady). -->
        <receiver
            android:name=".widget.RelaisWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/relais_widget_info" />
        </receiver>

        <!-- Opt-in only (RelaisConfig.autoStartEnabled, default false) -->
        <receiver
            android:name=".RelaisBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Watchdog: revives the node after a crash/OOM (START_STICKY alone insufficient) -->
        <receiver
            android:name=".RelaisWatchdogReceiver"
            android:exported="false" />

        <receiver
            android:name="cc.grepon.relais.notifications.NotificationReceiver"
            android:exported="false" />

        <receiver
            android:name="cc.grepon.relais.notifications.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <uses-native-library android:name="libvndksupport.so" android:required="false"/>
        <uses-native-library android:name="libOpenCL.so" android:required="false"/>
        <uses-native-library android:name="libcdsprpc.so" android:required="false" />
        <uses-native-library android:name="libedgetpu_litert.so" android:required="false" />
    </application>

</manifest>
