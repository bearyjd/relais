{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the Relais node /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "heatmap", "name": "Heatmap", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Relais on-device LLM node — Gate 3 observability. Per-endpoint latency, completion-token distribution, thermal events, and backpressure. Feature #10.",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["relais", "on-device", "llm"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Instance",
        "multi": false,
        "name": "instance",
        "options": [],
        "query": "label_values(relais_uptime_seconds, instance)",
        "refresh": 2,
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Relais Node",
  "panels": [
    {
      "id": 1,
      "title": "Per-endpoint p95 inference latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p95 of relais_inference_duration_seconds split by endpoint. Lets /generate p95 separate from /v1/chat/completions p95 (Feature #10).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(relais_inference_duration_seconds_bucket{instance=\"$instance\", endpoint!=\"\"}[5m])))",
          "legendFormat": "{{endpoint}} p95"
        }
      ]
    },
    {
      "id": 2,
      "title": "Global inference latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Quantiles over the unlabeled global series (the single tail guarantee recorded for every outcome, incl. timeouts).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(relais_inference_duration_seconds_bucket{instance=\"$instance\", endpoint=\"\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(relais_inference_duration_seconds_bucket{instance=\"$instance\", endpoint=\"\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(relais_inference_duration_seconds_bucket{instance=\"$instance\", endpoint=\"\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Completion-token distribution (heatmap)",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "relais_completion_tokens histogram — answer-length distribution over time (Feature #10).",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "options": { "calculate": false, "cellGap": 1, "yAxis": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (le) (rate(relais_completion_tokens_bucket{instance=\"$instance\"}[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Completion tokens p50 / p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Quantiles of completion-token counts.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(relais_completion_tokens_bucket{instance=\"$instance\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(relais_completion_tokens_bucket{instance=\"$instance\"}[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "title": "Thermal events rate by level",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "rate(relais_thermal_events_total) by level — catches transient SEVERE between scrapes that the gauge misses (Feature #10).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (level) (rate(relais_thermal_events_total{instance=\"$instance\"}[5m]))",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Shed / queue-reject / error rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Backpressure signals: 503 shed, 429 queue-reject, 5xx errors.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(relais_shed_total{instance=\"$instance\"}[5m])",
          "legendFormat": "shed (503)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(relais_queue_rejected_total{instance=\"$instance\"}[5m])",
          "legendFormat": "queue reject (429)"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(relais_errors_total{instance=\"$instance\"}[5m])",
          "legendFormat": "errors (5xx)"
        }
      ]
    },
    {
      "id": 7,
      "title": "Decode throughput (tok/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "relais_decode_tokens_per_second — the throughput-floor signal feeding thermal shedding.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "relais_decode_tokens_per_second{instance=\"$instance\"}",
          "legendFormat": "tok/s"
        }
      ]
    },
    {
      "id": 8,
      "title": "Queue depth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "relais_queue_depth — in-flight + queued inference requests.",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "relais_queue_depth{instance=\"$instance\"}",
          "legendFormat": "depth"
        }
      ]
    },
    {
      "id": 9,
      "title": "Thermal status / headroom",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Current thermal status (0=none..6=shutdown) and forecast headroom (>=1.0 == throttling).",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "relais_thermal_status{instance=\"$instance\"}",
          "legendFormat": "status"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "relais_thermal_headroom{instance=\"$instance\"}",
          "legendFormat": "headroom"
        }
      ]
    },
    {
      "id": 10,
      "title": "Uptime / restarts",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "relais_uptime_seconds and the prefs-persisted relais_restarts_total (watchdog restarts).",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "relais_uptime_seconds{instance=\"$instance\"}",
          "legendFormat": "uptime (s)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "relais_restarts_total{instance=\"$instance\"}",
          "legendFormat": "restarts"
        }
      ]
    }
  ]
}
